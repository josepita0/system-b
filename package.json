{
  "name": "system-barra",
  "version": "1.0.0",
  "description": "Sistema local de gestion de barra con Electron, React y SQLite.",
  "main": "dist-electron/src/main/index.js",
  "scripts": {
    "native:electron": "electron-rebuild -f -w better-sqlite3",
    "native:node": "npm rebuild better-sqlite3",
    "dev": "npm run native:electron && concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist-electron/src/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:main": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "npm run native:node && vitest run",
    "test:watch": "npm run native:node && vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "nodemailer": "^8.0.2",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-static-copy": "^3.3.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
